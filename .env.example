# ============================================================
# MediShield — environment variables
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# ------------------------------------------------------------
# MinIO  (object storage)
# Default credentials work with the bundled Docker service.
# Change for production.
# ------------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=medishield-documents

# ------------------------------------------------------------
# PostgreSQL  (cases database)
# ------------------------------------------------------------
POSTGRES_USER=medishield
POSTGRES_PASSWORD=medishield
POSTGRES_DB=medishield

# ------------------------------------------------------------
# Redis  (Celery broker + case cache)
# Only needed when running services outside Docker.
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Frontend
# URL the browser uses to reach the FastAPI backend.
# Keep http://localhost:8000 for local dev.
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
